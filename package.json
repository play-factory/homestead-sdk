{
  "name": "homestead-sdk-cli",
  "version": "0.0.0",
  "private": true,
  "description": "Public Homestead TypeScript SDK and CLI workspace",
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm --filter './packages/*' build",
    "typecheck": "pnpm --filter './packages/*' typecheck",
    "test": "pnpm --filter './packages/*' test",
    "check": "pnpm typecheck && pnpm test",
    "pack:dry-run": "pnpm --filter './packages/*' exec npm pack --dry-run"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
