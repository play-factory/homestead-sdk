{
  "name": "@homestead/sdk",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "pnpm build",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "vitest run",
    "check": "pnpm typecheck && pnpm test"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "description": "TypeScript SDK and API client for Homestead",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "package.json"
  ]
}
